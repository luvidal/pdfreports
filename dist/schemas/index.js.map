          "label": "Fecha de Ingreso",
          "source": { "doctype": "liquidaciones-sueldo", "field": "fecha_ingreso" },
          "format": "date"
        },
        "permanencia_anos": {
          "label": "Permanencia en la Empresa",
          "source": { "doctype": "liquidaciones-sueldo", "field": "fecha_ingreso" },
          "format": "years_since",
          "suffix": " anos"
        }
      }
    },
